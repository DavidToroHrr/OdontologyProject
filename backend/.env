# ─── CONFIGURACIÓN DE EMAIL ──────────────────────────────────────────────────
# 
# IMPORTANTE: Renombra este archivo a ".env" (sin el ".example")
# ¡NUNCA subas el archivo .env a GitHub!
#
# ── OPCIÓN 1: Gmail (recomendado) ─────────────────────────────────────────────
# 1. Ve a tu cuenta de Google → Seguridad
# 2. Activa "Verificación en 2 pasos" si no la tienes
# 3. Busca "Contraseñas de aplicación"
# 4. Genera una nueva contraseña para "Correo" > "Otro dispositivo"
# 5. Copia los 16 caracteres que te da Google aquí:

EMAIL_USER=davide.toroh@autonoma.edu.co
EMAIL_PASS=bqzn ragw pzng vrgs
   # Contraseña de aplicación de 16 chars (NO tu contraseña normal)
EMAIL_RECEIVER=juanp.torov@autonoma.edu.co
GEMINI_API_KEY=
